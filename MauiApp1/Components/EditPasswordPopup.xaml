<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:MauiApp1.Controls"
    xmlns:models="clr-namespace:MauiApp1.Models"
    x:Class="MauiApp1.Components.EditPasswordPopup"
    x:TypeArguments ="models:EditPasswordResult"
    Padding="0"
    Margin="0"
    HorizontalOptions="FillAndExpand"
    VerticalOptions="End"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border BackgroundColor="{DynamicResource Primary}" HorizontalOptions="FillAndExpand">

        <VerticalStackLayout Padding="10" Spacing="10">

            <!-- header -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Zmień hasło" VerticalOptions="Center" FontSize="Large"/>
                <Border Grid.Column="1" BackgroundColor="{DynamicResource Primary}" WidthRequest="30" HeightRequest="30">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="CloseTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="✕" VerticalOptions="Center" FontSize="Large"/>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="5">

                <controls:MyEntry x:Name="OldPasswordEntry"
                                  Placeholder="Obecne Hasło"
                                  BackgroundColor="{DynamicResource Primary}"
                                  TextColor="{DynamicResource Text}" PlaceholderColor="{DynamicResource FadedText}"
                                  IsPassword="True"/>

                <controls:MyEntry x:Name="NewPasswordEntry"
                                  Placeholder="Nowe hasło"
                                  BackgroundColor="{DynamicResource Primary}"
                                  TextColor="{DynamicResource Text}" PlaceholderColor="{DynamicResource FadedText}"
                                  IsPassword="True"/>

                <controls:MyEntry x:Name="NewPasswordRetypeEntry"
                                  Placeholder="Powtórz nowe hasło"
                                  BackgroundColor="{DynamicResource Primary}"
                                  TextColor="{DynamicResource Text}" PlaceholderColor="{DynamicResource FadedText}"
                                  IsPassword="True"/>

                <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- zapisz -->
            <Border Style="{StaticResource NavButton}" HeightRequest="50">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="SaveTapped"/>
                </Border.GestureRecognizers>
                <Label InputTransparent="True" Style="{StaticResource OptionLabel}">
                    Zapisz
                </Label>
            </Border>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>