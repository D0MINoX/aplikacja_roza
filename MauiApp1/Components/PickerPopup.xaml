<?xml version="1.0" encoding="utf-8" ?>
<layouts:Popup  xmlns:layouts="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                x:Class="MauiApp1.Components.PickerPopup"
                CanBeDismissedByTappingOutsideOfPopup="True"
                BackgroundColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}">
    <VerticalStackLayout Spacing="20">
        <!-- ten label jest tylko po to zeby zmieniac kolor popup dynamicnie -->
        <Label x:Name="Ref" BackgroundColor="{DynamicResource Primary}" IsEnabled="False" IsVisible="False" />
        
        <Label x:Name="PickerLabel">
            Wybierz część różańca
        </Label>

        <VerticalStackLayout x:Name="Picker" Spacing="10"/>

    </VerticalStackLayout>
</layouts:Popup>
