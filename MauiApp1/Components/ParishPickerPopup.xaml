<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                x:Class="MauiApp1.Components.ParishPickerPopup"
                CanBeDismissedByTappingOutsideOfPopup="True"
                BackgroundColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}">
    
    <VerticalStackLayout Spacing="20">
        <!-- ten label jest tylko po to zeby zmieniac kolor popup dynamicnie -->
        <Label x:Name="Ref" BackgroundColor="{DynamicResource Primary}" IsEnabled="False" IsVisible="False" />

        <Label x:Name="PickerLabel">
            Wybierz Swoją parafie
        </Label>

        <Grid RowDefinitions="auto">
            <ScrollView Grid.Row="0">
                <VerticalStackLayout x:Name="Picker" Spacing="10"/>
            </ScrollView>
        </Grid>

    </VerticalStackLayout>
    
</toolkit:Popup>
