<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:mauiapp1="clr-namespace:MauiApp1"
             x:Class="MauiApp1.SettingsPage"
             Title="SettingsPage">
    <Grid RowDefinitions="*,auto">
        <Grid RowDefinitions="auto,*" Padding="20" Grid.Row="0" RowSpacing="100">
            
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource Primary}" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="auto,auto">
                    <Image Grid.Column="0" Source="settings_icon.png" HeightRequest="100" WidthRequest="100" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Style="{StaticResource OptionLabel}" FontSize="Large">
                        Ustawienia
                    </Label>
                </Grid>
            </Border>

            <!-- Options -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="50">
                    
                    <!-- Zaloguj się -->
                    <Border Style="{StaticResource MenuOption}" x:Name="LogIn">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Login_Tapped"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                            <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource OptionImage}"/>
                            <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                                Zaloguj się
                            </Label>
                        </Grid>
                    </Border>
                    
                    <!-- Wyloguj -->
                    <Border Style="{StaticResource MenuOption}" x:Name="LogOut">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Logout_Tapped"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                            <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource OptionImage}"/>
                            <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                                Wyloguj się
                            </Label>
                        </Grid>
                    </Border>
                    
                    <!-- Profil -->
                    <Border Style="{StaticResource MenuOption}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Profile_Tapped"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                            <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource OptionImage}"/>
                            <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                                Profil
                            </Label>
                        </Grid>
                    </Border>
                    
                    <!-- Motyw -->
                    <Border Style="{StaticResource MenuOption}">
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                            <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource OptionImage}"/>
                            <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                                Zmień motyw
                            </Label>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
        <mauiapp1:BottomMenu Grid.Row="1"/>
    </Grid>
</ContentPage>