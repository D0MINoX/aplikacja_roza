<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.RegisterPage"
             xmlns:mauiapp1="clr-namespace:MauiApp1"
             Title="RegisterPage">
    <Grid RowDefinitions="*,auto">
        <Grid RowDefinitions="auto,*" Padding="20" Grid.Row="0" RowSpacing="10">
            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource Header}">
                <Grid ColumnDefinitions="auto,auto">
                    <Image Grid.Column="0" Source="book_icon.png" Style="{StaticResource HeaderImage}"/>
                    <Label Grid.Column="1" Style="{StaticResource HeaderLabel}">
                        Rejestracja
                    </Label>
                </Grid>
            </Border>

            <!-- Panel z rejestracją -->
            <VerticalStackLayout Padding="20" Spacing="5" Grid.Row="1">
                <Border Padding="25"
                     StrokeShape="RoundRectangle 20"
                     BackgroundColor="{DynamicResource Primary}"
                     StrokeThickness="0">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Utwórz swoje konto" 
                            FontSize="24" 
                            FontAttributes="Bold" 
                            HorizontalOptions="Center" 
                            TextColor="{DynamicResource Text}" />

                        <Entry x:Name="NameEntry" 
                            Placeholder="Imię" 
                            HeightRequest="45"
                            PlaceholderColor="{DynamicResource FadedText}"
                            TextColor="{DynamicResource Text}"/>

                        <Entry x:Name="SurnameEntry" 
                            Placeholder="Nazwisko" 
                            HeightRequest="45"
                            PlaceholderColor="{DynamicResource FadedText}"
                            TextColor="{DynamicResource Text}"/>

                        <Entry x:Name="EmailEntry" 
                            Placeholder="Email" 
                            Keyboard="Email"
                            HeightRequest="45"
                            PlaceholderColor="{DynamicResource FadedText}"
                            TextColor="{DynamicResource Text}"/>

                        <Entry x:Name="PasswordEntry" 
                            Placeholder="Hasło" 
                            IsPassword="True" 
                            HeightRequest="45"
                            PlaceholderColor="{DynamicResource FadedText}"
                            TextColor="{DynamicResource Text}"/>

                        <Entry x:Name="PasswordRetype" 
                             Placeholder="Powtórz Hasło" 
                             IsPassword="True" 
                             HeightRequest="45"
                             PlaceholderColor="{DynamicResource FadedText}"
                             TextColor="{DynamicResource Text}"/>
                        <Picker x:Name="ParishPicker"
                           Title="Wybierz z listy lub zostaw puste"
                            ItemDisplayBinding="{Binding Name}"
                           HeightRequest="45"
                           TitleColor="{DynamicResource FadedText}"
                           TextColor="{DynamicResource Text}"/>

                        <Label Text="Jeśli nie widzisz swojej parafii, możesz ją pominąć."
           FontSize="10" TextColor="Gray" HorizontalOptions="Center" />
                        
                        <Button Text="ZAREJESTRUJ SIĘ" 
                          Clicked="Register_Clicked"
                          CornerRadius="10"
                          HeightRequest="50"
                          Margin="0,10,0,0"
                          BackgroundColor="{DynamicResource Secondary}"
                          TextColor="{DynamicResource Text}"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
        <mauiapp1:BottomMenu Grid.Row="1"/>
    </Grid>
</ContentPage>