<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauiapp1="clr-namespace:MauiApp1"
             x:Class="MauiApp1.Views.SelectParish"
             Title="SelectParish"
             BackgroundColor="{DynamicResource Primary}">

    <Grid RowDefinitions="auto,*,auto,auto" RowSpacing="10">

        <!-- Header -->
        <Grid Grid.Row="0" Style="{StaticResource Head}">
            <Label Grid.Row="0" Style="{StaticResource HeaderLabel}">
                Wybierz parafię
            </Label>
            <Label Grid.Row="1" Style="{StaticResource HeaderLabel2}">
                Wybierz parafię, do której należysz
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ParishContainer"/>
        </ScrollView>

        <Border Grid.Row="2" Style="{StaticResource NavButton}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="Select_Tapped"/>
            </Border.GestureRecognizers>
            <Label Style="{StaticResource OptionLabel}">
                Wybierz
            </Label>
        </Border>

        <mauiapp1:BottomMenu Grid.Row="3"/>
    </Grid>

</ContentPage>