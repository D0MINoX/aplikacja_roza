<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.RosaryMenagementPage"
             Title="RosaryMenagementPage">
    <VerticalStackLayout>
        <!-- Header -->
        <Border Style="{StaticResource Header}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="UserVerification_Tapped"/>
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="auto,auto">
                <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource HeaderImage}"/>
                <Label Grid.Column="1" Style="{StaticResource HeaderLabel}">
                    Zażądzaj różami
                </Label>
            </Grid>
        </Border>
        
        <Border Style="{StaticResource MenuOption}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="UserVerification_Tapped"/>
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                <Image Grid.Column="0" Source="flower_icon.png" Style="{StaticResource OptionImage}"/>
                <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                    weryfikacja użytkowników
                </Label>
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentPage>