<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.RosaryMenagementPage"
             Title="RosaryMenagementPage">
    <VerticalStackLayout>
        <Border  Background="{StaticResource Kafelki}" Padding="15">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="UserVerification_Tapped"/>
            </Border.GestureRecognizers>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="auto,auto">
                <Image Grid.Column="0" Source="flower_icon.png" HeightRequest="100" WidthRequest="100" VerticalOptions="Center"/>
                <Label Grid.Column="1" TextColor="{StaticResource Text}" VerticalOptions="Center" FontSize="Large">
                    weryfikacja użytkowników
                </Label>
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentPage>