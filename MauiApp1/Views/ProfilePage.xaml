<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauiapp1="clr-namespace:MauiApp1" 
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MauiApp1.ProfilePage"
             Title="ProfilePage"
             BackgroundColor="{DynamicResource Primary}">

    <Grid RowDefinitions="*,auto">
        <!-- ten label jest tylko po to zeby zmieniac kolor ikonek dynamicnie -->
        <Label x:Name="Ref" BackgroundColor="{DynamicResource Tertiary}" IsEnabled="False" IsVisible="False" />
        
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20">
                
                <!-- Header -->
                <Grid Style="{StaticResource Head}">
                    <Label Grid.Row="0" Style="{StaticResource HeaderLabel}">
                        Profil
                    </Label>
                    <!--
                    <Label Grid.Row="1" Style="{StaticResource HeaderLabel2}">
                        ustawienia
                    </Label>
                    -->
                </Grid>

                <!-- dane profilu -->
                <Border Style="{StaticResource MenuOption}">
                    <VerticalStackLayout Spacing="10">
                        
                        <Label Style="{StaticResource OptionLabel}" HorizontalOptions="Start" x:Name="Name"/>
                        <Label Style="{StaticResource OptionLabel}" HorizontalOptions="Start" x:Name="Role"/>
                        <Label Style="{StaticResource OptionLabel}" HorizontalOptions="Start" x:Name="ParishLabel"/>

                        <!-- Edycja danych -->
                        <Border Style="{StaticResource NavButton}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="UserEditTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,auto" ColumnSpacing="20">
                                <Label Grid.Column="0" Style="{StaticResource OptionLabel}" HorizontalOptions="Start">
                                    Edytuj profil
                                </Label>
                                <Image Grid.Column="1" Source="right_arrow.png" HorizontalOptions="End" WidthRequest="30" HeightRequest="30">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                                    </Image.Behaviors>
                                </Image>
                            </Grid>
                        </Border>

                        <!-- Edycja hasła -->
                        <Border Style="{StaticResource NavButton}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="PasswordEditTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,auto" ColumnSpacing="20">
                                <Label Grid.Column="0" Style="{StaticResource OptionLabel}" HorizontalOptions="Start">
                                    Zmień hasło
                                </Label>
                                <Image Grid.Column="1" Source="right_arrow.png" HorizontalOptions="End" WidthRequest="30" HeightRequest="30">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                                    </Image.Behaviors>
                                </Image>
                            </Grid>
                        </Border>
                        
                    </VerticalStackLayout>
                </Border>

                <!-- panel admina -->
                <Border Style="{StaticResource MenuOption}" x:Name="adminBtn" IsVisible="False">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="AdminBtn_Clicked"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="auto,auto" ColumnSpacing="20">
                        <Image Grid.Column="0" Source="settings.png" Style="{StaticResource OptionImage}">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                            Panel administracyjny
                        </Label>
                    </Grid>
                </Border>

                <!-- dolacz do grupy -->
                <Border Style="{StaticResource MenuOption}" x:Name="RosariesContainer" IsVisible="False">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="JoinBtn_Clicked"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="auto,auto" ColumnSpacing="20">
                        <Image Grid.Column="0" Source="flower.png" Style="{StaticResource OptionImage}">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                            Dołącz do róży
                        </Label>
                    </Grid>
                </Border>

                <!-- wyloguj -->
                <Border Style="{StaticResource MenuOption}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Logout_Clicked"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="auto,auto" ColumnSpacing="20">
                        <Image Grid.Column="0" Source="logout.png" Style="{StaticResource OptionImage}">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                            Wyloguj się
                        </Label>
                    </Grid>
                </Border>
                
                <!--USUŃ-->
                <Border Style="{StaticResource MenuOption}">
                    <Grid RowDefinitions="*,*" >

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="DeleteTapped"/>
                        </Grid.GestureRecognizers>
                        <Grid ColumnDefinitions="auto,auto" ColumnSpacing="20">
                            <Image Grid.Column="0" Source="logout.png" Style="{StaticResource OptionImage}">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Grid.Column="1" Style="{StaticResource OptionLabel}">
                                USUŃ KONTO
                            </Label>

                        </Grid>

                        <controls:MyEntry x:Name="PasswordEntry"
                                          Placeholder="Hasło"
                                          IsPassword="True"
                                          Grid.Row="1"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <mauiapp1:BottomMenu Grid.Row="1"/>
    </Grid>
</ContentPage>
 
