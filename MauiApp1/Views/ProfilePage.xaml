<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.ProfilePage"
             Title="ProfilePage">
    <VerticalStackLayout>
        <Label 
            x:Name="Name"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Label x:Name="Role" VerticalOptions="Center" HorizontalOptions="Center"/>
        <VerticalStackLayout x:Name="adminBtn"/>
        <VerticalStackLayout  x:Name="RosariesContainer">
            <Border  Background="{DynamicResource Primary}" Padding="15">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="MyRosary_Tapped"/>
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="auto,auto">
                    <Image Grid.Column="0" Source="flower_icon.png" HeightRequest="100" WidthRequest="100" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="Rosary" TextColor="{DynamicResource Text}" VerticalOptions="Center" FontSize="Large">

                    </Label>
                </Grid>
            </Border>
        </VerticalStackLayout>
        
       
        <Button Clicked="Logout_Clicked" Text="Wyloguj"/>
    </VerticalStackLayout>
</ContentPage>