<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauiapp1="clr-namespace:MauiApp1"
             x:Class="MauiApp1.Views.MessagesPage"
             Title="MessagesPage">
    <Grid RowDefinitions="*, auto">
        <CollectionView Grid.Row="0" x:Name="MessagesList" Margin="15">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Brak nowych ogłoszeń" HorizontalTextAlignment="Center" TextColor="Gray"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="0,0,0,15">
                        <Border StrokeShape="RoundRectangle 15" 
                                BackgroundColor="{DynamicResource Primary}"
                                StrokeThickness="1"
                                Stroke="{DynamicResource Accent}">
                            <VerticalStackLayout Padding="15" Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" 
                                           Text="{Binding MessageTitle}" 
                                           FontAttributes="Bold" 
                                           FontSize="16"
                                           TextColor="{DynamicResource Text}"/>
                                    <Label Grid.Column="1" 
                                           Text="{Binding CreatedAt, StringFormat='{0:dd.MM HH:mm}'}" 
                                           FontSize="11" 
                                           TextColor="Gray" 
                                           VerticalOptions="Center"/>
                                </Grid>

                                <Label Text="{Binding MessageBody}" 
                                       TextColor="{DynamicResource Text}" 
                                       LineBreakMode="WordWrap"
                                       FontSize="14"/>

                                <BoxView HeightRequest="1" Color="{DynamicResource Secondary}" Margin="0,5"/>

                                <Label Text="{Binding AuthorName, StringFormat='Od: {0}'}" 
                                       FontSize="12" 
                                       FontAttributes="Italic"
                                       TextColor="{DynamicResource Accent}"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <BoxView x:Name="OverlayBackground"
         BackgroundColor="#AA000000"
         Opacity="0"
         IsVisible="False"
         Grid.Row="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCancelClicked"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border x:Name="AddMessagePanel"
        Grid.Row="0"
        Padding="20"
        Margin="20"
        BackgroundColor="{DynamicResource Secondary}"
        StrokeShape="RoundRectangle 15"
        StrokeThickness="2"
        Stroke="{DynamicResource Accent}"
        VerticalOptions="Center" 
        HorizontalOptions="Center"
        WidthRequest="320"
        IsVisible="False"
        Opacity="0"
        Scale="0.8">
            <VerticalStackLayout Spacing="10">
                <Label Text="Nowe ogłoszenie" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Text}"/>

                <Border StrokeShape="RoundRectangle 5" StrokeThickness="1" Stroke="{DynamicResource Accent}">
                    <Entry x:Name="NewTitleEntry" Placeholder="Tytuł wiadomości..." BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource Text}"/>
                </Border>

                <Border StrokeShape="RoundRectangle 5" StrokeThickness="1" Stroke="{DynamicResource Accent}">
                    <Editor x:Name="NewBodyEditor" Placeholder="Treść wiadomości..." HeightRequest="150" AutoSize="Disabled" BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource Text}"/>
                </Border>

                <Grid ColumnDefinitions="*, *">
                    <Button Grid.Column="0" Text="Anuluj" Clicked="OnCancelClicked" BackgroundColor="Gray" TextColor="White" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Text="Wyślij" Clicked="OnSendMessageClicked" BackgroundColor="{DynamicResource Accent}" TextColor="White" Margin="5,0,0,0"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Button x:Name="FabButton"
        Text="+"
        FontSize="24"
        FontAttributes="Bold"
        BackgroundColor="{DynamicResource Accent}"
        TextColor="White"
        CornerRadius="30"
        HeightRequest="60"
        WidthRequest="60"
        Padding="0"
        HorizontalOptions="End"
        VerticalOptions="End"
        Margin="0,0,20,20"
        Clicked="OnFabClicked"/>

        <mauiapp1:BottomMenu Grid.Row="1"></mauiapp1:BottomMenu>
    </Grid>
</ContentPage>