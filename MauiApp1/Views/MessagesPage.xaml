<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauiapp1="clr-namespace:MauiApp1"
             x:Class="MauiApp1.Views.MessagesPage"
             Title="MessagesPage">
    <Grid RowDefinitions="*, auto">
        <CollectionView Grid.Row="0" x:Name="MessagesList" Margin="15">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Brak nowych ogłoszeń" HorizontalTextAlignment="Center" TextColor="Gray"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="0,0,0,15">
                        <Border StrokeShape="RoundRectangle 15" 
                                BackgroundColor="{DynamicResource Primary}"
                                StrokeThickness="1"
                                Stroke="{DynamicResource Accent}">
                            <VerticalStackLayout Padding="15" Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" 
                                           Text="{Binding MessageTitle}" 
                                           FontAttributes="Bold" 
                                           FontSize="16"
                                           TextColor="{DynamicResource Text}"/>
                                    <Label Grid.Column="1" 
                                           Text="{Binding CreatedAt, StringFormat='{0:dd.MM HH:mm}'}" 
                                           FontSize="11" 
                                           TextColor="Gray" 
                                           VerticalOptions="Center"/>
                                </Grid>

                                <Label Text="{Binding MessageBody}" 
                                       TextColor="{DynamicResource Text}" 
                                       LineBreakMode="WordWrap"
                                       FontSize="14"/>

                                <BoxView HeightRequest="1" Color="{DynamicResource Secondary}" Margin="0,5"/>

                                <Label Text="{Binding AuthorName, StringFormat='Od: {0}'}" 
                                       FontSize="12" 
                                       FontAttributes="Italic"
                                       TextColor="{DynamicResource Accent}"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <mauiapp1:BottomMenu Grid.Row="1"></mauiapp1:BottomMenu>
    </Grid>
</ContentPage>