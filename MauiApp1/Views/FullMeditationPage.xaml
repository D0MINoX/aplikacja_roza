<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.FullMeditationPage"
             Title="FullMeditationPage">
    <Grid RowDefinitions="*,auto">
        <Grid RowDefinitions="auto,auto" Padding="20" Grid.Row="0" RowSpacing="10">
            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource Header}">
                <Grid ColumnDefinitions="auto,auto" ColumnSpacing="10">
                    <Image Grid.Column="0" Source="book_icon.png" Style="{StaticResource HeaderImage}"/>
                    <Label Grid.Column="1" Style="{StaticResource HeaderLabel}">
                        Rozważania różańcowe
                    </Label>
                </Grid>
            </Border>

            <!-- Całe rozważanie -->
            <Grid RowDefinitions="auto,auto" Grid.Row="1" RowSpacing="10">
                <Border Grid.Row="0" Style="{StaticResource MenuOption}" HeightRequest="-1">
                    <Grid RowDefinitions="auto,*,auto" RowSpacing="20" Padding="10" >
                        <!-- data -->
                        <Label Grid.Row="0" x:Name="DateLabel" InputTransparent="True"/>
                        <!-- tekst rozważania -->
                        <ScrollView Grid.Row="1" Orientation="Vertical" MaximumHeightRequest="400">
                            <Label VerticalOptions="Center" x:Name="FullMeditation" InputTransparent="True"/>
                        </ScrollView>
                       
                        <!-- przyciski -->
                        <Grid ColumnDefinitions="*,*" Grid.Row="2">
                            <Border Grid.Column="0" Background="{DynamicResource Secondary}" HorizontalOptions="Start" Padding="10" WidthRequest="100">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                
                                <Label HorizontalOptions="Center" InputTransparent="True">
                                    Cofnij
                                </Label>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource Secondary}"
                                    HorizontalOptions="End"
                                    Padding="10"
                                    WidthRequest="100"
                                    Stroke="{DynamicResource Accent}"
                                    StrokeThickness="3"
                                    x:Name="Complete">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="CompletedTapped"/>
                                </Border.GestureRecognizers>
                                <Label HorizontalOptions="Center" InputTransparent="True">
                                    Ukończono
                                </Label>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>