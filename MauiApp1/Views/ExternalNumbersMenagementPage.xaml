<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ExternalNumbersMenagementPage"
            xmlns:conv="clr-namespace:MauiApp1.Converters"
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             Title="ExternalNumbersMenagementPage">
    <Grid RowDefinitions="*,auto">
        
   
    <Grid RowDefinitions="Auto, *" Margin="10" Grid.Row="0">
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*, 150" BackgroundColor="{DynamicResource Secondary}" Padding="10">
            <Label Text="Użytkownik" FontAttributes="Bold" TextColor="White" Grid.Column="0"/>
            <Label Text="Numer telefonu" FontAttributes="Bold" TextColor="White" Grid.Column="1"/>
            <Label Text="Róża" FontAttributes="Bold" TextColor="White" Grid.Column="2"/>
            <Label Text="Dodano" FontAttributes="Bold" TextColor="White" Grid.Column="3"/>

            <Label Text="Akcje" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Grid.Column="4"/>
        </Grid>

            <CollectionView Grid.Row="1" x:Name="NumbersList" VerticalScrollBarVisibility="Always">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 0" StrokeThickness="0.5" Stroke="{DynamicResource Accent}">
                        <Grid ColumnDefinitions="*, *,*,*, 150" Padding="10" BackgroundColor="{DynamicResource Primary}">

                            <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
                                    <Label Text="{Binding Name}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEditing}"
                                                 Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Entry Text="{Binding Name}" TextColor="Black">
                                        <Entry.Triggers>
                                            <DataTrigger TargetType="Entry"
                                                 Binding="{Binding IsEditing}"
                                                 Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Entry.Triggers>
                                    </Entry>
                                    <Label Text="{Binding Surname}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEditing}"
                                                 Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Entry x:Name="SurnameEntry"
                                        Placeholder="Nazwisko"
                                           Text="{Binding Surname}" TextColor="Black">
                                        <Entry.Triggers>
                                            <DataTrigger TargetType="Entry"
                                                 Binding="{Binding IsEditing}"
                                                 Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Entry.Triggers>
                                    </Entry>
                                </HorizontalStackLayout>

                                <Label Text="{Binding PhoneNumber}" 
                               VerticalOptions="Center" 
                               Grid.Column="1" 
                               FontSize="12"
                                >
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsEditing}"
                                                 Value="True">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Entry x:Name="PhoneNumberEntry"
                                    Placeholder="numer telefonu"
                                    Grid.Column="1" 
                                       TextColor="Black"
                                    Text="{Binding PhoneNumber}">
                                    <Entry.Triggers>
                                        <DataTrigger TargetType="Entry"
                                             Binding="{Binding IsEditing}"
                                             Value="False">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Entry.Triggers>
                                </Entry>
                                <Label Text="{Binding RosaryId}" 
                                VerticalOptions="Center" 
                                Grid.Column="2" 
                                FontSize="12"/>
                            <Label Text="{Binding CreatedAt}" 
                                VerticalOptions="Center" 
                                Grid.Column="3" 
                                FontSize="12"/>

                            <HorizontalStackLayout Grid.Column="4" Spacing="5" HorizontalOptions="Center">
                                
                                <Button Text="🗑"
                                        FontSize="12"
                                        BackgroundColor="Red" 
                                        TextColor="White"
                                        HeightRequest="35" WidthRequest="35" Padding="0"
                                        Clicked="OnDeleteClicked" 
                                        CommandParameter="{Binding .}"/>
                                    <Button Text="✏️"
        FontSize="12"
        BackgroundColor="CadetBlue"
        HeightRequest="35"
        WidthRequest="35"
        Padding="0"
        Clicked="OnEditClicked"
        CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                     Binding="{Binding IsEditing}"
                     Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="💾"
        FontSize="12"
        BackgroundColor="Green"
        TextColor="White"
        HeightRequest="35"
        WidthRequest="35"
        Padding="0"
        Clicked="OnSaveClicked"
        CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                     Binding="{Binding IsEditing}"
                     Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    <Border Style="{StaticResource MenuOption}" x:Name="newNumber" IsVisible="False" Grid.Row="1">
        <VerticalStackLayout Spacing="5">

            <Label Text="Dodaj zewnętrzenego użytkownika"
               Style="{StaticResource HeaderLabel}"
               HorizontalOptions="Center"/>

            <controls:MyEntry x:Name="NameEntry"
                          Placeholder="Imię"/>

            <controls:MyEntry x:Name="SurnameEntry"
                          Placeholder="Nazwisko"/>

            <controls:MyEntry x:Name="PhoneEntry"
                          Placeholder="numer telefonu"/>

                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                <CheckBox x:Name="AcceptTermsCheckBox" Color="{DynamicResource Text}"/>
                <Label VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>

                                <Span Text="Oświadczam że mam zgodę pisemną lub ustną osoby na wpisanie jej do systemu powiadomień SMS" />

                                <Span Text="Polityka Prywatności"
                              TextColor="{DynamicResource Tertiary}"
                              TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OpenPrywatnoscClicked" />
                                </Span.GestureRecognizers>
                            </Span>
                            <Span Text="*" TextColor="red"/>

                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <Border Style="{StaticResource NavButton}" HeightRequest="50" WidthRequest="250">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RegisterClicked"/>
                </Border.GestureRecognizers>
                <Label InputTransparent="True" Style="{StaticResource OptionLabel}">
                    Dodaj osobę
                </Label>
            </Border>

        </VerticalStackLayout>
    </Border>
        <Button x:Name="FabButton"
            Text="+"
            FontSize="24"
            FontAttributes="Bold"
            BackgroundColor="{DynamicResource Accent}"
            TextColor="White"
            CornerRadius="30"
            HeightRequest="60"
            WidthRequest="60"
            Padding="0"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,20,20"
            Clicked="OnFabClicked"/>
    </Grid>
</ContentPage>