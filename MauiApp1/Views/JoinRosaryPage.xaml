<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.JoinRosaryPage"
              xmlns:mauiapp1="clr-namespace:MauiApp1"
             Title="JoinRosaryPage"
             BackgroundColor="{DynamicResource Primary}">
    
    <Grid RowDefinitions="auto,*,auto,auto,auto" RowSpacing="10">
        
        <!-- Header -->
        <Grid Grid.Row="0" Style="{StaticResource Head}">
            <Label Grid.Row="0" Style="{StaticResource HeaderLabel}">
                Dołącz do róży
            </Label>
            <Label Grid.Row="1" Style="{StaticResource HeaderLabel2}">
                Wybierz róże, do której chcesz dołączyć
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="RosariesContainer"/>
        </ScrollView>
        
        <Border Grid.Row="2" Style="{StaticResource NavButton}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="JoinButton_Tapped"/>
            </Border.GestureRecognizers>
            <Label Style="{StaticResource OptionLabel}">
                Dołącz
            </Label>
        </Border>
        
        <Border Grid.Row="3" Style="{StaticResource NavButton}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="SelectParish_Tapped"/>
            </Border.GestureRecognizers>
            <Label Style="{StaticResource OptionLabel}">
                Wybierz inną parafię
            </Label>
        </Border>
        
        <mauiapp1:BottomMenu Grid.Row="4"/>
    </Grid>
</ContentPage>