<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauiapp1="clr-namespace:MauiApp1"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MauiApp1.MyRosaryPage"
             Title="MyRosaryPage"
             BackgroundColor="{DynamicResource Primary}">
    
    <Grid RowDefinitions="*,auto">

        <!-- ten label jest tylko po to zeby zmieniac kolor ikonek dynamicznie -->
        <Label x:Name="Ref" BackgroundColor="{DynamicResource Tertiary}" IsEnabled="False" IsVisible="False" />

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20">

                <!-- Header -->
                <Grid Style="{StaticResource Head}">
                    <Label Grid.Row="0" Style="{StaticResource HeaderLabel}">
                        Moja róża
                    </Label>
                    <Label Grid.Row="1" Style="{StaticResource HeaderLabel2}" x:Name="rosaryName">
                        *nazwa róży*
                    </Label>
                </Grid>
                
                <!-- Można tu zrobić wyświetlanie najnowszej wiadomości -->

                <!-- Wiadomości -->
                <Border Style="{StaticResource MenuOption}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Messages_Tapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="auto,auto" ColumnSpacing="20">
                        <Image Grid.Column="0" Source="message_icon.png" Style="{StaticResource OptionImage}">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{Binding Source={x:Reference Ref}, Path=BackgroundColor}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1" Style="{StaticResource OptionLabel}" x:Name="MessagesLabel">
                            Wyświetl wiadomości
                        </Label>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <mauiapp1:BottomMenu Grid.Row="1"/>
    </Grid>
</ContentPage>