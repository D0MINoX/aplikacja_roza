<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ChangeUserPrivilagiesPage"
             Title="ChangeUserPrivilagiesPage">
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto, *" Margin="10">
            <Grid Grid.Row="0" ColumnDefinitions="*, *, 150" BackgroundColor="{DynamicResource Secondary}" Padding="10">
                <Label Text="Użytkownik" FontAttributes="Bold" TextColor="White" Grid.Column="0"/>
                <Label Text="Rola" FontAttributes="Bold" TextColor="White" Grid.Column="1"/>
                <Label Text="Akcje" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Grid.Column="2"/>
            </Grid>

            <CollectionView Grid.Row="1" x:Name="UsersList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 0" StrokeThickness="0.5" Stroke="{DynamicResource Accent}">
                            <Grid ColumnDefinitions="*, *, 150" Padding="10" BackgroundColor="{DynamicResource Primary}">

                                <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
                                    <Label Text="{Binding UserName}" />
                                    <Label Text="{Binding UserSurname}" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding RosaryName}" 
                        VerticalOptions="Center" 
                        Grid.Column="1" 
                        FontSize="12"/>

                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </VerticalStackLayout>
</ContentPage>