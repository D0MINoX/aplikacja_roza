<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:mauiapp1="clr-namespace:MauiApp1"
             x:Class="MauiApp1.RosaryMeditationsPage"
             Title="RosaryMeditationsPage">
    <Grid RowDefinitions="*,auto">
        <Grid RowDefinitions="auto,auto" Padding="20" Grid.Row="0" RowSpacing="100">
            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource Kafelki}" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="auto,auto">
                    <Image Grid.Column="0" Source="book_icon.png" HeightRequest="100" WidthRequest="100" VerticalOptions="Center"/>
                    <Label Grid.Column="1" TextColor="{StaticResource Text}" VerticalOptions="Center" FontSize="Large">
                        Rozważania różańcowe
                    </Label>
                </Grid>
            </Border>
            <!-- change date & short of meditation -->
            <Grid RowDefinitions="auto,auto" Grid.Row="1">
                <Border Background="{StaticResource Kafelki}" Grid.Row="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="MeditationTapped"/>
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Grid RowDefinitions="auto,auto,auto" RowSpacing="10" Padding="20" >
                        <!-- data -->
                        <Label Grid.Row="0" x:Name="DateLabel" InputTransparent="True"/>
                        <!-- tekst rozważania -->
                        <Label Grid.Row="1" TextColor="{StaticResource Text}" VerticalOptions="Center" MaxLines="6" LineBreakMode="TailTruncation" x:Name="MeditationLabel" InputTransparent="True"/>


                        <!-- przyciski do zmiany daty -->
                        <Grid ColumnDefinitions="*,*" Grid.Row="2">
                            <Border Grid.Column="0" Background="{StaticResource Menu}" HorizontalOptions="Start" Padding="10" WidthRequest="100">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="PreviousTapped"/>
                                </Border.GestureRecognizers>
                                <Label TextColor="{StaticResource Text}" HorizontalOptions="Center" InputTransparent="True">
                                    Wstecz
                                </Label>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource Menu}" HorizontalOptions="End" Padding="10" WidthRequest="100">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="NextTapped"/>
                                </Border.GestureRecognizers>
                                <Label TextColor="{StaticResource Text}" HorizontalOptions="Center" InputTransparent="True">
                                    Dalej
                                </Label>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                <!-- YT button -->
                <Border Background="{StaticResource Kafelki}" HeightRequest="100" Grid.Row="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="20">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped=""/>
                        </Grid.GestureRecognizers>
                        <Image Grid.Column="0" Source="play_icon.png" HeightRequest="70" WidthRequest="70" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <Label Grid.Column="1" TextColor="{StaticResource Text}" VerticalOptions="Center">
                            Obejrzyj film
                        </Label>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <mauiapp1:BottomMenu Grid.Row="1"/>
    </Grid>
</ContentPage>